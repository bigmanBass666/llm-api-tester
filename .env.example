# ============================================
# API Key 环境变量配置模板
# ============================================
# 使用方法：
# 1. 复制此文件为 .env.local
# 2. 填入真实的 API key
# 3. 切勿将 .env.local 提交到 git！
#
# .gitignore 已包含：
#   .env
#   .env.*
#   !.env.example

# ----------------------------
# NVIDIA NIM API
# ----------------------------
# 获取地址：https://build.nvidia.com
# 参考：https://docs.nvidia.com/nim/latest/chatbot.html
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------
# 智谱 AI GLM API
# ----------------------------
# 获取地址：https://www.bigmodel.cn/usercenter/proj-mgmt/rate-limits
# 参考：https://open.bigmodel.cn/api/doc
ZHIPU_API_KEY=508431.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------
# 阿里云百炼
# ----------------------------
# 获取地址：https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------
# 腾讯云混元
# ----------------------------
# 获取地址：https://console.cloud.tencent.com/cam/capi
TENCENTCLOUD_SECRET_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TENCENTCLOUD_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------
# SSL 配置（Windows 用户）
# ----------------------------
# 如果遇到 SSL 证书错误，取消注释并设置：
# SSL_CERT_FILE=D:/apps/python312/Lib/site-packages/certifi/cacert.pem
# REQUESTS_CA_BUNDLE=D:/apps/python312/Lib/site-packages/certifi/cacert.pem
